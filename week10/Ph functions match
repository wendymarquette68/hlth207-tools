  <script>
  'use strict';
  const SERVICES = [
    {
      id:'s1', correct:'assess',
      text:'Monitor health status to identify community health problems',
      explanation:'Monitoring and surveillance are the core of the Assessment function. In 2024, U.S. life expectancy reached a record high of 79 years (CDC, January 2026), but still trails comparable countries by 3.7 years. That gap was only visible because of ongoing surveillance work now at risk: by end of 2025 the CDC had lost roughly a quarter of its workforce, including the epidemiologists and data scientists who run these systems.'
    },
    {
      id:'s2', correct:'assess',
      text:'Diagnose and investigate health problems and health hazards in the community',
      explanation:'Outbreak investigation is Assessment at its most urgent. In 2025, measles outbreaks spread across multiple states while Dallas County was forced to cancel 50 immunization clinics because federal funding was clawed back. The CDC\'s Epidemic Intelligence Service, which trains the disease detectives who investigate outbreaks, faced deep cuts in 2025 as part of the broader HHS restructuring.'
    },
    {
      id:'s3', correct:'policy',
      text:'Inform, educate, and empower people about health issues',
      explanation:'Health communication is a Policy Development function: it builds the public understanding needed to support evidence-based decisions and behavior change. In 2025, vaccine communication campaigns were among the public health programs cut or halted when HHS clawed back $11.4 billion in previously approved state grants. Immunization rates fell in communities that lost this outreach infrastructure.'
    },
    {
      id:'s4', correct:'policy',
      text:'Mobilize community partnerships to identify and solve health problems',
      explanation:'Building coalitions across sectors is Policy Development work. In 2025 and 2026, dozens of advocacy coalitions, including the American Public Health Association, Trust for America\'s Health, and 23 state governments filing lawsuits, mobilized partnerships in direct response to federal public health funding cuts. This is the essential service your senator letter activates.'
    },
    {
      id:'s5', correct:'policy',
      text:'Develop policies and plans that support individual and community health',
      explanation:'Writing, championing, and implementing health policy is the defining work of Policy Development. Senators are voting right now on FY2026 appropriations that would cut CDC funding by up to 53% and eliminate agencies including SAMHSA, HRSA, and NIOSH. Your Health Advocacy Project letter lands directly in this function.'
    },
    {
      id:'s6', correct:'assure',
      text:'Enforce laws and regulations that protect health and ensure safety',
      explanation:'Enforcement is Assurance: existing protections only work if they are actively upheld. The National Institute for Occupational Safety and Health (NIOSH), which enforces workplace safety standards for 160 million U.S. workers, was proposed for elimination in the FY2026 HHS restructuring. Eliminating the agency does not repeal the laws; it eliminates the Assurance that those laws are enforced.'
    },
    {
      id:'s7', correct:'assure',
      text:'Link people to needed personal health services and assure provision of care when otherwise unavailable',
      explanation:'Connecting people to care is an Assurance obligation. The Health Resources and Services Administration (HRSA), which funds community health centers serving 30 million patients who have no other access point, was proposed for elimination in March 2025. Over 1,400 federally qualified health centers nationwide depend on HRSA funding to keep their doors open.'
    },
    {
      id:'s8', correct:'assure',
      text:'Assure a competent public health and personal healthcare workforce',
      explanation:'Workforce development is Assurance: the system cannot deliver any of the other nine services without skilled people. U.S. health departments already needed approximately 80,000 additional workers before 2025 (Health Affairs). By February 2026, CDC had lost over 3,000 workers through firings, early retirements, and resignations. Federal workers historically had the lowest exit rates in healthcare; that changed sharply in 2025.'
    },
    {
      id:'s9', correct:'assure',
      text:'Evaluate effectiveness, accessibility, and quality of personal and population-based health services',
      explanation:'Quality evaluation is Assurance: it ensures that services are actually working and reaching everyone equitably. The Agency for Healthcare Research and Quality (AHRQ), the primary federal agency responsible for this evaluation function, was demoted from an independent HHS agency to a sub-agency of the new Office of Strategy in the March 2025 HHS restructuring, reducing its independence and capacity.'
    },
    {
      id:'s10', correct:'assess',
      text:'Research new insights and innovative solutions to health problems',
      explanation:'Research generates the evidence base that drives all of public health, making it a core Assessment function. In 2025, the National Institutes of Health faced proposed cuts of $18 billion in the FY2026 budget, the largest proposed cut in NIH history. More than 100 public health programs and funding lines would be eliminated under the proposed budget, including 61 programs at CDC alone.'
    }
  ];

  const FUNCTION_LABELS = { assess:'Assessment', policy:'Policy Development', assure:'Assurance' };
  const SCORE_MESSAGES = {
    10:'Perfect score! You have a strong command of how the public health system is organized.',
    9:'Excellent work. You understand the framework very well.',
    8:'Great job. Review the ones you missed and you will have this down.',
    7:'Good effort. A couple of the service assignments are tricky — the explanations will help.',
    6:'Take a close look at the Assurance services, which are the most numerous group.',
    5:'Keep at it. The explanations below will help clarify the distinctions between functions.',
    4:'This is a good learning opportunity. Review the function definitions and try again.',
    3:'Take your time with the function definitions and give it another try.',
    2:'Review the three core functions on the welcome screen and try again.',
    1:'Start fresh from the welcome screen and read each function description carefully.',
    0:'No worries. Review the three function definitions and try again.'
  };

  let answers = {}, submitted = false;
  const $ = id => document.getElementById(id);
  const announce = msg => { $('live-region').textContent=''; setTimeout(()=>$('live-region').textContent=msg,50); };
  const showScreen = id => {
    document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
    $(id).classList.add('active');
    const h = $(id).querySelector('h2,h3,[tabindex="-1"]');
    if(h){ h.setAttribute('tabindex','-1'); h.focus(); }
  };

  function buildCards(){
    const c=$('cards-container'); c.innerHTML=''; answers={}; submitted=false;
    SERVICES.forEach((svc,i)=>{
      const card=document.createElement('div');
      card.className='service-card'; card.setAttribute('role','listitem'); card.id=`card-${svc.id}`;
      card.innerHTML=`
        <p class="service-num" aria-hidden="true">Service ${i+1} of 10</p>
        <p class="service-text" id="label-${svc.id}">${svc.text}</p>
        <fieldset class="radio-group" aria-labelledby="label-${svc.id}" aria-describedby="feedback-${svc.id}">
          <legend class="sr-only">Assign service ${i+1} to a core function</legend>
          ${['assess','policy','assure'].map(fn=>`
            <div class="radio-option ${fn}">
              <input type="radio" id="radio-${svc.id}-${fn}" name="${svc.id}" value="${fn}" aria-label="${FUNCTION_LABELS[fn]}">
              <label for="radio-${svc.id}-${fn}">${FUNCTION_LABELS[fn]}</label>
            </div>`).join('')}
        </fieldset>
        <div class="card-feedback" id="feedback-${svc.id}" role="note" aria-live="polite"></div>`;
      c.appendChild(card);
      card.querySelectorAll('input[type="radio"]').forEach(r=>{
        r.addEventListener('change',()=>{ if(submitted) return; answers[svc.id]=r.value; updateProgress(); });
      });
    });
  }

  function updateProgress(){
    const n=Object.keys(answers).length;
    $('progress-text').textContent=`${n} of 10 answered`;
    $('answered-num').textContent=n;
    $('progress-bar').style.width=`${n*10}%`;
    const pb=$('progress-bar-wrap'); pb.setAttribute('aria-valuenow',n);
  }

  function submitAnswers(){
    if(Object.keys(answers).length===0){ announce('Please select at least one answer before checking.'); return; }
    submitted=true; let correct=0;
    SERVICES.forEach(svc=>{
      const card=$(`card-${svc.id}`), fb=$(`feedback-${svc.id}`), chosen=answers[svc.id];
      if(!chosen) return;
      card.querySelectorAll('input[type="radio"]').forEach(r=>r.disabled=true);
      if(chosen===svc.correct){
        correct++;
        card.classList.add('answered-correct');
        fb.className='card-feedback correct show';
        fb.innerHTML=`<span aria-hidden="true">&#10003;</span><span><strong>Correct.</strong> ${svc.explanation}</span>`;
      } else {
        card.classList.add('answered-wrong');
        fb.className='card-feedback wrong show';
        fb.innerHTML=`<span aria-hidden="true">&#10007;</span><span><strong>Not quite.</strong> The correct answer is <strong>${FUNCTION_LABELS[svc.correct]}</strong>. ${svc.explanation}</span>`;
      }
    });
    buildResults(correct);
    showScreen('screen-results');
    announce(`Activity complete. You scored ${correct} out of ${Object.keys(answers).length} answered. Review your results below.`);
  }

  function buildResults(correct){
    const answered=Object.keys(answers).length;
    $('score-display').textContent=`${correct} / ${answered}`;
    $('score-display').setAttribute('aria-label',`Score: ${correct} out of ${answered}`);
    $('score-label').textContent=`out of ${answered} answered${answered<10?' ('+(10-answered)+' skipped)':''}`;
    $('score-message').textContent=SCORE_MESSAGES[correct]||'';
    const byFn={assess:[],policy:[],assure:[]};
    SERVICES.forEach((svc,i)=>byFn[svc.correct].push(`${i+1}. ${svc.text}`));
    ['assess','policy','assure'].forEach(fn=>{
      $(`${fn}-services`).innerHTML=byFn[fn].map(s=>`<span style="display:block;font-size:.85rem;margin-bottom:.2rem;">${s}</span>`).join('');
    });
    const list=$('results-list'); list.innerHTML='';
    SERVICES.forEach((svc,i)=>{
      const chosen=answers[svc.id]; if(!chosen) return;
      const ok=chosen===svc.correct;
      const item=document.createElement('div');
      item.className=`result-item ${ok?'correct':'wrong'}`; item.setAttribute('role','listitem');
      item.innerHTML=`
        <span class="result-icon" aria-label="${ok?'Correct':'Incorrect'}">${ok?'&#10003;':'&#10007;'}</span>
        <div class="result-content">
          <p class="result-service">${i+1}. ${svc.text}</p>
          <p class="result-answer">${ok?`Correct: ${FUNCTION_LABELS[svc.correct]}`:`You answered: ${FUNCTION_LABELS[chosen]} &nbsp;&middot;&nbsp; Correct: ${FUNCTION_LABELS[svc.correct]}`}</p>
        </div>`;
      list.appendChild(item);
    });
  }

  function resetActivity(){ buildCards(); updateProgress(); showScreen('screen-quiz'); announce('Activity reset. All answers cleared.'); }

  $('btn-start').addEventListener('click',()=>{ buildCards(); updateProgress(); showScreen('screen-quiz'); announce('Activity started. Match each of the 10 essential services to its core function.'); });
  $('btn-submit').addEventListener('click',submitAnswers);
  $('btn-clear').addEventListener('click',()=>{ if(confirm('Clear all your answers and start over?')) resetActivity(); });
  $('btn-retry').addEventListener('click',resetActivity);
  $('btn-back-welcome').addEventListener('click',()=>{ showScreen('screen-welcome'); announce('Returned to activity introduction.'); });
  </script>
</body>
</html>
